# Keep the Docker build context small.
__pycache__/
*.pyc
*.pyo
*.pyd
.git/
.venv/
.idea/
.vscode/

# Don't ship dev-only stuff
frames/
frames_*/
metrics.csv
*.gif
*.mp4

# Unused checkpoints — list each explicitly so we don't accidentally exclude
# checkpoints_sonar_v2 via prefix matching on some BuildKit versions.
/checkpoints
/checkpoints_v2
/checkpoints_sonar

# Dev requirements (Dockerfile uses requirements.web.txt instead)
requirements.txt
